<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" styleClass="root" stylesheets="@packageStyle.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.photostudio.Controller.PackagePageController">
    <children>

        <Label layoutX="30.0" layoutY="30.0" styleClass="page-title" text="Package Management" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="30.0" />

        <Button contentDisplay="RIGHT" graphicTextGap="10.0" layoutX="820.0" layoutY="19.0" mnemonicParsing="false" onAction="#onClickAdditionalServices" prefHeight="45.0" prefWidth="250.0" styleClass="btn-special" text="Additional Services" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="19.0">
            <graphic>
                <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" fill="WHITE" scaleX="0.9" scaleY="0.9" />
            </graphic>
        </Button>

        <HBox layoutX="30.0" layoutY="85.0" spacing="30.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="85.0">
            <children>

                <VBox prefHeight="500.0" prefWidth="320.0" spacing="15.0" styleClass="form-panel">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="section-header" text="Package Details" />

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Package ID" />
                            <TextField fx:id="txtPackageId" onKeyPressed="#handleSearchPackage" promptText="P001" styleClass="text-field-custom" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Package Name" />
                            <TextField fx:id="txtPackageName" promptText="Ex: Gold Wedding" styleClass="text-field-custom" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Category" />
                            <ComboBox fx:id="cmbCategory" maxWidth="1.7976931348623157E308" promptText="Select Category" styleClass="combo-box-custom" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Base Price" />
                            <TextField fx:id="txtPrice" promptText="0.00" styleClass="text-field-custom" />
                        </VBox>

                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <Label styleClass="input-label" text="Description" />
                            <TextArea fx:id="txtDescription" prefHeight="80.0" promptText="Enter details..." styleClass="text-area-custom" wrapText="true" />
                        </VBox>

                        <HBox spacing="10.0">
                            <Button fx:id="btnSave" maxWidth="1.7976931348623157E308" onAction="#handleSavePackage" styleClass="btn, btn-save" text="Save" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnUpdate" maxWidth="1.7976931348623157E308" onAction="#handleUpdatePackage" styleClass="btn, btn-update" text="Update" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox spacing="10.0">
                            <Button fx:id="btnDelete" maxWidth="1.7976931348623157E308" onAction="#handleDeletePackage" styleClass="btn, btn-delete" text="Delete" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnReset" maxWidth="1.7976931348623157E308" onAction="#handleResetPackage" styleClass="btn, btn-reset" text="Reset" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" styleClass="table-panel" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" styleClass="search-box">
                            <children>
                                <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#95a5a6" scaleX="1.2" scaleY="1.2" />
                                <TextField fx:id="txtSearch" promptText="Search Packages..." styleClass="search-field" HBox.hgrow="ALWAYS">
                                    <HBox.margin><Insets left="10.0" /></HBox.margin>
                                </TextField>
                            </children>
                            <padding><Insets bottom="5.0" left="10.0" right="10.0" top="5.0" /></padding>
                        </HBox>

                        <TableView fx:id="tblPackages" onMouseClicked="#handleTableClick" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colPackageId" prefWidth="70.0" text="ID" />
                                <TableColumn fx:id="colPackageName" prefWidth="150.0" text="Name" />
                                <TableColumn fx:id="colCategory" prefWidth="100.0" text="Category" />
                                <TableColumn fx:id="colPrice" prefWidth="90.0" text="Price" />

                                <TableColumn fx:id="colDescription" prefWidth="150.0" text="Description" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
