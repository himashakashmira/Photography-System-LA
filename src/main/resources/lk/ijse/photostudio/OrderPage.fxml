<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" styleClass="root" stylesheets="@orderStyle.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.photostudio.Controller.OrderPageController">
    <children>
        <Label layoutX="30.0" layoutY="20.0" styleClass="page-title" text="Order &amp; Payments" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="20.0" />

        <HBox layoutX="30.0" layoutY="70.0" spacing="30.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="70.0">
            <children>
                <VBox prefHeight="500.0" prefWidth="320.0" spacing="15.0" styleClass="form-panel">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label styleClass="section-header" text="Order Details" />

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Order ID" />
                            <TextField fx:id="txtOrderId" promptText="ORD001" styleClass="text-field-custom" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Select Booking" />
                            <ComboBox fx:id="cmbBookingId" maxWidth="1.7976931348623157E308" promptText="Select Booking ID" styleClass="combo-box-custom" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Package Price" />
                            <TextField fx:id="txtPkgPrice" editable="false" promptText="Auto-Filled" styleClass="text-field-custom" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="input-label" text="Options Price" />
                            <TextField fx:id="txtOptPrice" editable="false" promptText="Auto-Filled" styleClass="text-field-custom" />
                        </VBox>

                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <Label styleClass="input-label" text="Grand Total" />
                            <TextField fx:id="txtTotal" editable="false" promptText="0.00" style="-fx-font-weight: bold;" styleClass="text-field-custom" />
                        </VBox>

                        <HBox spacing="10.0">
                            <Button maxWidth="1.7976931348623157E308" onAction="#handlePlaceOrder" styleClass="btn, btn-save" text="Place Order" HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnDelete" maxWidth="1.7976931348623157E308" styleClass="btn, btn-delete" text="Cancel" HBox.hgrow="ALWAYS" />
                            <Button maxWidth="1.7976931348623157E308" onAction="#handleReset" styleClass="btn, btn-reset" text="Reset" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="15.0" styleClass="table-panel" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" styleClass="search-box">
                            <children>
                                <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#95a5a6" scaleX="1.2" scaleY="1.2" />
                                <TextField fx:id="txtSearch" promptText="Search Orders..." styleClass="search-field" HBox.hgrow="ALWAYS">
                                    <HBox.margin><Insets left="10.0" /></HBox.margin>
                                </TextField>
                            </children>
                            <padding><Insets bottom="5.0" left="10.0" right="10.0" top="5.0" /></padding>
                        </HBox>

                        <TableView fx:id="tblOrders" onMouseClicked="#handleTableClick" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colOrderId" prefWidth="80.0" text="Order ID" />
                                <TableColumn fx:id="colBookingId" prefWidth="90.0" text="Booking ID" />
                                <TableColumn fx:id="colCustomerId" prefWidth="76.0" text="Customer ID" />
                                <TableColumn fx:id="colPkgPrice" prefWidth="108.0" text="Package Price" />
                                <TableColumn fx:id="colOptPrice" prefWidth="90.0" text="Opt Price" />
                        <TableColumn fx:id="colGrandTotal" prefWidth="111.0" text="Grand Total" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
